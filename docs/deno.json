{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run -A src/main.ts",
    "build": "deno run -A src/main.ts --build",
    "start": "deno run -A dist/server.js",
    "check": "deno check .",
    "lint": "deno lint ."
  },
  "imports": {
    "@dreamer/dweb": "jsr:@dreamer/dweb@^3.3.1",
    "@dreamer/render": "jsr:@dreamer/render@^1.1.5",
    "@dreamer/router": "jsr:@dreamer/router@^1.1.3",
    "@dreamer/runtime-adapter": "jsr:@dreamer/runtime-adapter@^1.0.18",
    "@dreamer/upload": "jsr:@dreamer/upload@^1.0.1",
    "@dreamer/upload/adapters": "jsr:@dreamer/upload@^1.0.1/adapters",
    "@dreamer/upload/server": "jsr:@dreamer/upload@^1.0.1/server",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.0.9",
    "@dreamer/theme": "jsr:@dreamer/theme@^1.0.1",
    "@dreamer/plugin": "jsr:@dreamer/plugin@^1.0.2",
    "@dreamer/service": "jsr:@dreamer/service@^1.0.2",
    "@dreamer/markdown": "jsr:@dreamer/markdown@^1.0.1",
    "chart.js": "npm:chart.js@^4.5.1",
    "chart.js/auto": "npm:chart.js@^4.5.1/auto",
    "prismjs": "npm:prismjs@^1.29.0",
    "preact": "npm:preact@10.28.3",
    "preact/jsx-runtime": "npm:preact@10.28.3/jsx-runtime",
    "preact/hooks": "npm:preact@10.28.3/hooks",
    "preact/compat": "npm:preact@10.28.3/compat",
    "@preact/signals": "npm:@preact/signals@2.2.0",
    "@dreamer/ui-preact": "../src/mod.ts",
    "@dreamer/ui-preact/form": "../src/desktop/form/mod.ts",
    "@dreamer/ui-preact/basic": "../src/desktop/basic/mod.ts",
    "@dreamer/ui-preact/shared": "../src/shared/mod.ts",
    "@dreamer/ui-preact/mobile": "../src/mobile/mod.ts",
    "@dreamer/ui-preact/mobile/basic": "../src/mobile/basic/mod.ts",
    "@dreamer/ui-preact/plugin": "../plugin.ts",
    "tailwind-merge": "npm:tailwind-merge@^2.6.0",
    "postcss": "npm:postcss@8.4.39",
    "tailwindcss": "npm:tailwindcss@4.1.18",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@4.1.18"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": [
      "deno.window",
      "dom"
    ]
  },
  "exclude": [
    "dist/",
    "runtime/"
  ],
  "lint": {
    "include": [
      "src/"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  }
}
